{
  "statusLine": {
    "type": "command",
    "command": "bash $CLAUDE_PROJECT_DIR/.claude/ctx-protocol/scripts/statusline.sh"
  },
  "permissions": {
    "allow": [
      "Bash(bash .claude/ctx-protocol/scripts/ctx.sh print-handoff-info)",
      "Bash(bash .claude/ctx-protocol/scripts/ctx.sh print-handoff-content)",
      "Bash(bash .claude/ctx-protocol/scripts/ctx.sh print-settings)"
    ]
  },
  "hooks": {
    "SessionStart": [
      { "matcher": "*", "hooks": [{ "type": "command", "command": "bash $CLAUDE_PROJECT_DIR/.claude/ctx-protocol/scripts/ctx.sh hook session_start" }] }
    ],
    "Stop": [
      { "matcher": "*", "hooks": [{ "type": "command", "command": "bash $CLAUDE_PROJECT_DIR/.claude/ctx-protocol/scripts/ctx.sh hook stop", "timeout": 25 }] }
    ],
    "PreCompact": [
      { "matcher": "*", "hooks": [{ "type": "command", "command": "bash $CLAUDE_PROJECT_DIR/.claude/ctx-protocol/scripts/ctx.sh hook pre_compact", "timeout": 30 }] }
    ],
    "PostCompact": [
      { "matcher": "*", "hooks": [{ "type": "command", "command": "bash $CLAUDE_PROJECT_DIR/.claude/ctx-protocol/scripts/ctx.sh hook post_compact" }] }
    ],
    "SessionEnd": [
      { "matcher": "*", "hooks": [{ "type": "command", "command": "bash $CLAUDE_PROJECT_DIR/.claude/ctx-protocol/scripts/ctx.sh hook session_end", "timeout": 30 }] }
    ]
  }
}
